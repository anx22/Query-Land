{
  "name": "@seo-tool/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run vercel-build",
    "start": "next start",
    "build:next": "DATABASE_URL=sqlite::memory: next build",
    "build:deps": "npm --workspace @seo-tool/domain-model run build && npm --workspace @seo-tool/shared-config run build && npm --workspace @seo-tool/api run build",
    "vercel-build": "npm run build:deps && npm run build:next"
  },
  "dependencies": {
    "@seo-tool/api": "0.1.0",
    "@seo-tool/domain-model": "0.1.0",
    "@seo-tool/shared-config": "0.1.0",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.9.2"
  }
}
