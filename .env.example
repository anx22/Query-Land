DATABASE_URL=sqlite:data/seo-os.sqlite
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Google Search Console OAuth (see DOCS/deployment/google-oauth-setup.md).
# Required to connect a real GSC data source; without these the connect button stays disabled and
# all GSC-backed modules show honest empty states.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
# Secret used to encrypt stored OAuth refresh tokens (AES-256-GCM). Use a long random string.
OAUTH_ENCRYPTION_KEY=
