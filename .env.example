DATABASE_URL=pglite:data/seo-os.sqlite
# Hinweis: das "sqlite:"-Präfix wird aus Rückwärts-Kompatibilität ebenfalls akzeptiert
# (mappt intern auf PGlite, nicht auf echtes SQLite). Siehe apps/api/src/db/index.ts.
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Google Search Console OAuth (see DOCS/deployment/google-oauth-setup.md).
# Required to connect a real GSC data source; without these the connect button stays disabled and
# all GSC-backed modules show honest empty states.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
# Secret used to encrypt stored OAuth refresh tokens (AES-256-GCM). Use a long random string.
OAUTH_ENCRYPTION_KEY=

# Report delivery.
# Webhook delivery needs nothing here (the app POSTs the report JSON to the URL you enter per schedule).
# Email delivery uses Resend (free tier): set the API key + a sender. Without RESEND_API_KEY the
# "email" channel is honestly marked "skipped" — it never fakes a send.
RESEND_API_KEY=
# Sender address for report emails. Use a verified Resend domain in production; onboarding@resend.dev
# works for testing without a verified domain.
REPORTS_FROM_EMAIL=onboarding@resend.dev
# Required so the daily Vercel cron (crawl refresh + due report schedules) can run. Long random string.
CRON_SECRET=
