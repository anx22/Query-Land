{
  "name": "seo-tool-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Internal SEO Operating System monorepo foundation.",
  "scripts": {
    "dev": "next dev apps/web",
    "build": "next build apps/web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "next lint apps/web"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
  "name": "seo-tool",
  "version": "0.1.0",
  "private": true,
  "description": "Internal SEO Operating System foundation monorepo.",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "npm run build && NODE_ENV=test node --test packages/domain-model/dist/test/*.test.js apps/api/dist/test/*.test.js",
    "typecheck": "tsc -b --pretty false",
    "dev": "node scripts/dev.mjs",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "validate:openapi": "node scripts/validate-openapi.mjs",
    "check": "npm run typecheck && npm run check:boundaries && npm run validate:openapi && npm test"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "typescript": "^5.9.2"
  }
}
