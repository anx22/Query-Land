{
  "name": "@seo-tool/crawler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./worker": {
      "types": "./dist/src/worker.d.ts",
      "default": "./dist/src/worker.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/src/worker.js",
    "start:once": "CRAWLER_ONCE=1 node dist/src/worker.js"
  },
  "dependencies": {
    "@seo-tool/domain-model": "0.1.0",
    "@seo-tool/api": "0.1.0",
    "@seo-tool/shared-config": "0.1.0"
  }
}
